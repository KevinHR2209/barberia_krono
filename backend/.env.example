# Configuración SMTP para envío de correos
# Copia este archivo como .env y completa los valores

# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion

# URL del frontend (para el botón de cancelación en el correo)
FRONTEND_URL=http://localhost:5173
